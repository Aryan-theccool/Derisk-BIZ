# ──────────────────────────────────────────────────────────────
# DeRisk.biz environment configuration
# Copy this file to `.env` and fill in your values.
# ──────────────────────────────────────────────────────────────

# MongoDB Atlas FREE tier (M0) connection string.
# 1. Create a free cluster at https://www.mongodb.com/cloud/atlas/register
# 2. Database Access → create a user with password
# 3. Network Access → allow 0.0.0.0/0 (or your server IP)
# 4. Connect → Drivers → copy the connection string below
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/derisk?retryWrites=true&w=majority

# Port for the Express server
PORT=3000

# Secret token to access /api/admin/* endpoints (send as X-Admin-Token header)
ADMIN_TOKEN=change-me-to-a-long-random-string
